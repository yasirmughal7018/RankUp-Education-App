{
  "Database": {
    "Provider": "PostgreSql",
    "EnsureApiSupportTables": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=RankUpEducation;Username=postgres;Password=Numerical@123"
  },
  "Jwt": {
    "Issuer": "RankUpEducation",
    "Audience": "RankUpEducation.Clients",
    "SigningKey": "CHANGE_ME_TO_A_SECURE_32_CHARACTER_MINIMUM_SECRET",
    "AccessTokenMinutes": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "RateLimiting": {
    "AuthPermitLimit": 30,
    "AuthWindowSeconds": 60,
    "LoginPermitLimit": 8,
    "LoginWindowSeconds": 60,
    "UsersAnonymousPermitLimit": 60,
    "UsersAnonymousWindowSeconds": 60,
    "ChangePasswordPermitLimit": 10,
    "ChangePasswordWindowSeconds": 60
  },
  "HealthChecks": {
    "Enabled": true,
    "LivePath": "/health/live",
    "ReadyPath": "/health/ready",
    "DetailedPath": "/health"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
