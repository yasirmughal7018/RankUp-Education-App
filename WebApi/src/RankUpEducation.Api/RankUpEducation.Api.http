@RankUpEducation.Api_HostAddress = http://localhost:5255

GET {{RankUpEducation.Api_HostAddress}}/api/health
Accept: application/json

###

# Login (Student, Parent, Teacher, SchoolAdmin, PortalAdmin)
POST {{RankUpEducation.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "student-demo",
  "password": "password"
}

###

# Login status (step 1: CNIC/mobile only)
POST {{RankUpEducation.Api_HostAddress}}/api/auth/login-status
Content-Type: application/json

{
  "username": "03XXXXXXXXX"
}

###

# After approval: set password only (then sign in with /auth/login)
POST {{RankUpEducation.Api_HostAddress}}/api/auth/set-initial-password
Content-Type: application/json

{
  "username": "03XXXXXXXXX",
  "newPassword": "YourNewPassword1"
}

###

@accessToken = {{login.response.body.data.accessToken}}
@refreshToken = {{login.response.body.data.refreshToken}}

# Current user
GET {{RankUpEducation.Api_HostAddress}}/api/auth/me
Authorization: Bearer {{accessToken}}

###

# Refresh token
POST {{RankUpEducation.Api_HostAddress}}/api/auth/token/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###

# Password reset request
POST {{RankUpEducation.Api_HostAddress}}/api/auth/password-reset/request
Content-Type: application/json

{
  "username": "student-demo"
}

###

# Logout
POST {{RankUpEducation.Api_HostAddress}}/api/auth/logout
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###

@quizId = 1

# List questions on a quiz (parent/teacher owner)
GET {{RankUpEducation.Api_HostAddress}}/api/quizzes/{{quizId}}/questions
Authorization: Bearer {{accessToken}}

###

# Add question to quiz
POST {{RankUpEducation.Api_HostAddress}}/api/quizzes/{{quizId}}/questions
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "questionText": "Which fraction is equivalent to 1/2?",
  "questionType": "Single Choice",
  "marks": 2,
  "estimatedTimeSeconds": 45,
  "hint": "Reduce each option.",
  "explanation": "2/4 simplifies to 1/2.",
  "options": [
    { "optionText": "2/4", "isCorrect": true },
    { "optionText": "1/3", "isCorrect": false },
    { "optionText": "3/5", "isCorrect": false }
  ]
}

###

@questionId = 1

# Question bank - list (optional filters: isActive, subjectId, classId, pendingApprovalOnly)
GET {{RankUpEducation.Api_HostAddress}}/api/questions?pendingApprovalOnly=false
Authorization: Bearer {{accessToken}}

###

# Pending approval queue (school admin)
GET {{RankUpEducation.Api_HostAddress}}/api/questions/pending-approval
Authorization: Bearer {{accessToken}}

###

# Create standalone question (starts in Pending status)
POST {{RankUpEducation.Api_HostAddress}}/api/questions
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "questionText": "What is 7 x 8?",
  "questionType": "Single Choice",
  "classId": 1,
  "subjectId": 1,
  "topicId": 1,
  "difficultyLevel": 1,
  "marks": 1,
  "estimatedTimeSeconds": 30,
  "hint": null,
  "explanation": "56",
  "options": [
    { "optionText": "56", "isCorrect": true },
    { "optionText": "54", "isCorrect": false }
  ]
}

###

# Update question bank item
PUT {{RankUpEducation.Api_HostAddress}}/api/questions/{{questionId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "questionText": "What is 7 x 8?",
  "questionType": "Single Choice",
  "classId": 1,
  "subjectId": 1,
  "topicId": 1,
  "difficultyLevel": 1,
  "marks": 1,
  "estimatedTimeSeconds": 30,
  "hint": null,
  "explanation": "56",
  "options": [
    { "optionText": "56", "isCorrect": true },
    { "optionText": "54", "isCorrect": false }
  ]
}

###

# Approve question (school admin)
POST {{RankUpEducation.Api_HostAddress}}/api/questions/{{questionId}}/approve
Authorization: Bearer {{accessToken}}

###

# AI-approve question (super admin)
POST {{RankUpEducation.Api_HostAddress}}/api/questions/{{questionId}}/approve-ai
Authorization: Bearer {{accessToken}}

###

# Reject question (school admin)
POST {{RankUpEducation.Api_HostAddress}}/api/questions/{{questionId}}/reject
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "reason": "Incorrect answer key"
}

###

# Activate / deactivate
POST {{RankUpEducation.Api_HostAddress}}/api/questions/{{questionId}}/activate
Authorization: Bearer {{accessToken}}

###

POST {{RankUpEducation.Api_HostAddress}}/api/questions/{{questionId}}/deactivate
Authorization: Bearer {{accessToken}}

###

# Delete question (must not be linked to quizzes)
DELETE {{RankUpEducation.Api_HostAddress}}/api/questions/{{questionId}}
Authorization: Bearer {{accessToken}}

###

# Update question on quiz
PUT {{RankUpEducation.Api_HostAddress}}/api/quizzes/{{quizId}}/questions/{{questionId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "questionText": "Which fraction is equivalent to 1/2?",
  "questionType": "Single Choice",
  "marks": 2,
  "estimatedTimeSeconds": 45,
  "hint": "Reduce each option.",
  "explanation": "2/4 simplifies to 1/2.",
  "options": [
    { "optionText": "2/4", "isCorrect": true },
    { "optionText": "1/3", "isCorrect": false }
  ]
}

###

# Remove question from quiz
DELETE {{RankUpEducation.Api_HostAddress}}/api/quizzes/{{quizId}}/questions/{{questionId}}
Authorization: Bearer {{accessToken}}

###
