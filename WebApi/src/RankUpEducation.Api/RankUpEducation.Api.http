@RankUpEducation.Api_HostAddress = http://localhost:5255

GET {{RankUpEducation.Api_HostAddress}}/api/health
Accept: application/json

###

# Login (Student, Parent, Teacher, SchoolAdmin, SuperAdmin)
POST {{RankUpEducation.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "student-demo",
  "password": "password"
}

###

@accessToken = {{login.response.body.data.accessToken}}
@refreshToken = {{login.response.body.data.refreshToken}}

# Current user
GET {{RankUpEducation.Api_HostAddress}}/api/auth/me
Authorization: Bearer {{accessToken}}

###

# Refresh token
POST {{RankUpEducation.Api_HostAddress}}/api/auth/token/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###

# Password reset request
POST {{RankUpEducation.Api_HostAddress}}/api/auth/password-reset/request
Content-Type: application/json

{
  "username": "student-demo"
}

###

# Logout
POST {{RankUpEducation.Api_HostAddress}}/api/auth/logout
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###

@quizId = 1

# List questions on a quiz (parent/teacher owner)
GET {{RankUpEducation.Api_HostAddress}}/api/questions/quiz/{{quizId}}
Authorization: Bearer {{accessToken}}

###

# Add question to quiz
POST {{RankUpEducation.Api_HostAddress}}/api/questions/quiz/{{quizId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "questionText": "Which fraction is equivalent to 1/2?",
  "questionType": "Single Choice",
  "marks": 2,
  "estimatedTimeSeconds": 45,
  "hint": "Reduce each option.",
  "explanation": "2/4 simplifies to 1/2.",
  "options": [
    { "optionText": "2/4", "isCorrect": true },
    { "optionText": "1/3", "isCorrect": false },
    { "optionText": "3/5", "isCorrect": false }
  ]
}

###

@questionId = 1

# Update question on quiz
PUT {{RankUpEducation.Api_HostAddress}}/api/questions/quiz/{{quizId}}/{{questionId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "questionText": "Which fraction is equivalent to 1/2?",
  "questionType": "Single Choice",
  "marks": 2,
  "estimatedTimeSeconds": 45,
  "hint": "Reduce each option.",
  "explanation": "2/4 simplifies to 1/2.",
  "options": [
    { "optionText": "2/4", "isCorrect": true },
    { "optionText": "1/3", "isCorrect": false }
  ]
}

###

# Remove question from quiz
DELETE {{RankUpEducation.Api_HostAddress}}/api/questions/quiz/{{quizId}}/{{questionId}}
Authorization: Bearer {{accessToken}}

###
